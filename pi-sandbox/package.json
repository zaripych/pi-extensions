{
  "name": "pi-sandbox",
  "version": "0.4.2",
  "description": "OS-level sandboxing for pi with interactive permission prompts",
  "keywords": [
    "pi-package",
    "pi-extension"
  ],
  "type": "module",
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carderne/pi-sandbox.git"
  },
  "author": "Chris Arderne <chris@rdrn.me>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/carderne/pi-sandbox/issues"
  },
  "homepage": "https://github.com/carderne/pi-sandbox",
  "scripts": {
    "fmt": "oxfmt index.ts",
    "lint": "oxlint index.ts",
    "check": "tsc --noEmit",
    "all": "npm run fmt && npm run lint && npm run check",
    "ci:fmt": "oxfmt --check index.ts",
    "ci:lint": "npm run lint",
    "ci:check": "npm run check"
  },
  "dependencies": {
    "@carderne/sandbox-runtime": "^0.0.49"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "26.0.0",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "typescript": "6.0.3"
  },
  "overrides": {
    "minimatch": ">=10.2.1",
    "lodash-es": ">=4.18.1"
  }
}
