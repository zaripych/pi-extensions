{
  "name": "pi-extensions",
  "private": true,
  "scripts": {
    "format": "prettier --write -u .",
    "lint": "oxlint",
    "lint-changed": "lint-staged --diff HEAD",
    "lint-staged": "lint-staged --hide-all",
    "prepare": "[ -d .git ] && husky || true",
    "test": "vitest run",
    "test-changed": "vitest run --changed",
    "typecheck": "tsgo --noEmit --pretty",
    "verify": "pnpm run \"/^(typecheck|lint|test-changed)$/\""
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "0.80.3",
    "@earendil-works/pi-coding-agent": "0.80.3",
    "@earendil-works/pi-tui": "0.80.3",
    "@types/node": "26.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260701.1",
    "expect-type": "1.3.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "^0.24.0",
    "prettier": "3.8.4",
    "sort-package-json": "4.0.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
