{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!node_modules",
      "!package-lock.json",
      "!!dist",
      "!!coverage"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "single"
    }
  },
  "plugins": [
    "./rules/no-type-assertions.grit",
    "./rules/no-angle-type-assertions.grit"
  ],
  "overrides": [
    {
      "includes": ["vitest.config.ts"],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.spec.ts", "**/*.harness.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "useAwait": "off"
          }
        }
      }
    }
  ],
  "linter": {
    "enabled": true,
    "domains": {
      "project": "recommended",
      "test": "recommended"
    },
    "rules": {
      "recommended": true,
      "complexity": {
        "noBannedTypes": "error",
        "noUselessTypeConstraint": "error"
      },
      "correctness": {
        "noUndeclaredDependencies": "error",
        "noUndeclaredVariables": "error",
        "noUnresolvedImports": "error",
        "noUnusedFunctionParameters": "error",
        "noUnusedImports": "error",
        "noUnusedPrivateClassMembers": "error",
        "noUnusedVariables": "error",
        "noVoidTypeReturn": "error",
        "useJsonImportAttributes": "error"
      },
      "nursery": {
        "noConditionalExpect": "error",
        "noFloatingPromises": "error",
        "noIdenticalTestTitle": "error",
        "noMisleadingReturnType": "error",
        "noMisusedPromises": "error",
        "noUnnecessaryConditions": "error",
        "noUnsafePlusOperands": "error",
        "useArraySortCompare": "error",
        "useAwaitThenable": "error",
        "useExhaustiveSwitchCases": "error",
        "useExpect": "error"
      },
      "performance": {
        "noBarrelFile": "error",
        "noNamespaceImport": "error",
        "noReExportAll": "error"
      },
      "style": {
        "noCommonJs": "error",
        "noDefaultExport": {
          "level": "error"
        },
        "noNonNullAssertion": "error",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "fs": "Use node:fs/promises instead of sync filesystem APIs.",
              "node:fs": "Use node:fs/promises instead of sync filesystem APIs."
            }
          }
        },
        "useExportType": "error",
        "useImportType": "error",
        "useNodejsImportProtocol": "error",
        "useShorthandFunctionType": "error"
      },
      "suspicious": {
        "noConfusingVoidType": "error",
        "noConstEnum": "error",
        "noConstantBinaryExpressions": "error",
        "noDeprecatedImports": "error",
        "noDuplicateTestHooks": "error",
        "noEvolvingTypes": "error",
        "noExplicitAny": "error",
        "noExportsInTest": "error",
        "noExtraNonNullAssertion": "error",
        "noFocusedTests": "error",
        "noImplicitAnyLet": "error",
        "noImportCycles": "error",
        "noMisplacedAssertion": "error",
        "noNonNullAssertedOptionalChain": "error",
        "noSkippedTests": "error",
        "noTsIgnore": "error",
        "noUnassignedVariables": "error",
        "noUnsafeDeclarationMerging": "error",
        "noUnusedExpressions": "error",
        "useAwait": "error",
        "useGuardForIn": "error"
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
