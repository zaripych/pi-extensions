{
  "name": "foundation",
  "private": true,
  "type": "module",
  "exports": {
    "./testing/harness/*": "./testing/harness/*.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check --config-path ./biome.config.json .",
    "test": "vitest run",
    "verify": "npm run typecheck && npm run lint && npm run test -- --changed"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "expect-type": "^1.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
